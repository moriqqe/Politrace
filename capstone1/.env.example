# Apify
APIFY_API_TOKEN=your_apify_token_here

# Telegram (from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+380XXXXXXXXX
# Set to 1 if login code does not arrive in the Telegram app
# TELEGRAM_FORCE_SMS=1

# Collection limits (per platform)
MAX_RECORDS_TWITTER=15000
MAX_RECORDS_TELEGRAM=15000
MAX_RECORDS=15000
OUTPUT_FORMAT=csv
